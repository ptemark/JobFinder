# Secrets for Job Finder (LLD §11.3). Copy to .env (gitignored — never commit).
# Adzuna is an OPTIONAL aggregator (spec §5). Leave blank to run on the direct
# ATS feeds only; both keys must be present for the Adzuna source to enable.
# Free-tier key: https://developer.adzuna.com/

ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# OPTIONAL The Muse aggregator key. The Muse runs key-free at a lower rate
# limit; a key just raises the ceiling. Free key: https://www.themuse.com/developers/api/v2
THEMUSE_API_KEY=

# OPTIONAL JSearch (RapidAPI) — broadest coverage, aggregates Google for Jobs
# (Indeed, LinkedIn, Glassdoor, ZipRecruiter). Skipped cleanly when absent.
# Free key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=
# Optional query tuning (defaults shown):
# JSEARCH_QUERY=backend developer
# JSEARCH_COUNTRY=ca
# JSEARCH_NUM_PAGES=1

# Optional Adzuna query tuning (LLD §3.6). Sensible defaults target Canadian
# backend roles; leave these unset to use them. `where` narrows the location
# within Canada (e.g. "Toronto"); `category` is an Adzuna category tag (e.g.
# "it-jobs").
# ADZUNA_WHAT=backend software engineer
# ADZUNA_WHERE=
# ADZUNA_CATEGORY=

# OPTIONAL M7 application-tracker sync (Google Sheet, spec §15 / LLD §16). Absent →
# marking a job "applied" still works locally and the sync is skipped cleanly. Both
# the credentials path AND the sheet id must be set to enable it. Create a free
# Google Cloud service account, download its JSON key to the path below (gitignored),
# and share the sheet (Editor) with the service account's email once.
GOOGLE_SHEETS_CREDENTIALS=        # path to the service-account JSON key, e.g. config/google-service-account.json
JOB_TRACKER_SHEET_ID=             # the spreadsheet id from its URL (.../d/<THIS>/edit)
JOB_TRACKER_SHEET_GID=            # optional worksheet gid (default: first sheet)
