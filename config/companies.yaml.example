# ATS board tokens to poll (LLD §11.2), keyed by source. Copy to companies.yaml.
# Each entry: {token, name, verified}. `token` is the board slug in the feed URL:
#   greenhouse -> boards-api.greenhouse.io/v1/boards/{token}/jobs
#   lever      -> api.lever.co/v0/postings/{token}
#   ashby      -> api.ashbyhq.com/posting-api/job-board/{token}
# `jobfinder add-company <ats> <token>` appends verified entries; aggregator
# discovery (T23) appends unverified ones. Set verified: true once confirmed.
#
# Starter seeds below are Canadian / remote-friendly employers. The exact board
# tokens are UNCONFIRMED — verify each against the live feed before trusting it,
# then flip `verified: true`. (# TODO verify)

greenhouse:
  - { token: "shopify", name: "Shopify", verified: false }        # TODO verify
  - { token: "benevity", name: "Benevity", verified: false }      # TODO verify
  - { token: "clio", name: "Clio", verified: false }              # TODO verify

lever:
  - { token: "jobber", name: "Jobber", verified: false }          # TODO verify
  - { token: "thinkific", name: "Thinkific", verified: false }    # TODO verify

ashby:
  - { token: "wealthsimple", name: "Wealthsimple", verified: false }  # TODO verify
